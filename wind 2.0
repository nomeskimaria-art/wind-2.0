<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>wind songs</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/tone/14.8.49/Tone.js"></script>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      min-height: 100dvh;
      overflow: hidden;
      background: #000;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      position: fixed;
      inset: 0;
    }

    .tool-canvas-area {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100dvh;
      overflow: hidden;
      background: #000;
    }

    canvas {
      position: absolute;
      inset: 0;
      width: 100vw !important;
      height: 100dvh !important;
      display: block;
      background: #000;
      object-fit: cover;
      touch-action: none;
    }
</style>
</head>
<body>
  <div class="tool-canvas-area">
    <canvas id="canvas"></canvas>
  </div>

  <script>

    // Mobile perf: cap devicePixelRatio so canvases allocate fewer pixels.
    (function() {
      var _isMobile = window.innerWidth <= 768;
      if (_isMobile) {
        var _nativeDPR = window.devicePixelRatio || 1;
        var _cappedDPR = Math.min(1.5, _nativeDPR);
        Object.defineProperty(window, 'devicePixelRatio', { get: function() { return _cappedDPR; } });
      }
    })();

    window.CanvasRuntimeAPI = (function() {
      var _exportMode = 'auto';
      var _exportWidth = 0;
      var _exportHeight = 0;
      var _bgState = { mode: 'none', color: '#ffffff', imageEl: null, imageDataURL: null, fit: 'cover' };
      var _cameraBridgeEnabled = false;
      var _cameraRequestSeq = 0;
      var _cameraSessions = {};
      var _cameraFrameListeners = [];
      var _cameraStopNotified = {};


      var _canvas = document.getElementById('canvas');
      var _area = _canvas ? _canvas.parentElement : document.querySelector('.tool-canvas-area');
      var _resizeRAF = null;

      function _detectCanvas() {
        var r = window.renderer || window.threeRenderer;
        if (r && r.domElement) {
          _canvas = r.domElement;
          _area = _canvas.parentElement;
          return;
        }
        var area = document.querySelector('.tool-canvas-area');
        if (area) {
          var canvases = area.querySelectorAll('canvas');
          var visible = [];
          for (var j = 0; j < canvases.length; j++) {
            if (canvases[j].style.display !== 'none') visible.push(canvases[j]);
          }
          if (visible.length >= 1) {
            var largest = visible[0];
            for (var i = 1; i < visible.length; i++) {
              if (visible[i].width * visible[i].height > largest.width * largest.height) {
                largest = visible[i];
              }
            }
            _canvas = largest;
            _area = _canvas.parentElement;
          }
        }
      }

      function _cameraFallbackConstraints(constraints) {
        return constraints || { audio: false, video: true };
      }

      function _makeCameraRequestId() {
        _cameraRequestSeq += 1;
        return 'camera-' + Date.now() + '-' + _cameraRequestSeq;
      }

      function _makeCameraCanvas(width, height) {
        var canvas = document.createElement('canvas');
        canvas.width = Math.max(1, Math.round(width || 1));
        canvas.height = Math.max(1, Math.round(height || 1));
        canvas.style.display = 'none';
        canvas.setAttribute('aria-hidden', 'true');
        document.body.appendChild(canvas);
        return canvas;
      }

      function _emitCameraFrame(session, payload) {
        var detail = {
          requestId: payload.requestId,
          width: session.canvas.width,
          height: session.canvas.height,
          timestamp: payload.timestamp || Date.now(),
          canvas: session.canvas,
          imageData: payload.imageData || null,
          stream: session.stream
        };
        for (var i = 0; i < _cameraFrameListeners.length; i++) {
          try {
            _cameraFrameListeners[i](detail);
          } catch (err) {
            setTimeout(function() { throw err; }, 0);
          }
        }
        if (typeof CustomEvent !== 'undefined') {
          window.dispatchEvent(new CustomEvent('clay:camera-frame', { detail: detail }));
        }
      }

      function _wrapCameraStream(stream, requestId) {
        if (!stream) return stream;
        try {
          Object.defineProperty(stream, '__clayCameraRequestId', {
            value: requestId,
            configurable: true
          });
        } catch (err) {}
        return stream;
      }

      function _captureNativeCameraFrame(session, timestamp) {
        if (!session.video || session.video.readyState < HTMLMediaElement.HAVE_CURRENT_DATA) {
          return;
        }
        var width = Math.max(1, session.video.videoWidth || session.canvas.width || 1);
        var height = Math.max(1, session.video.videoHeight || session.canvas.height || 1);
        if (session.canvas.width !== width) session.canvas.width = width;
        if (session.canvas.height !== height) session.canvas.height = height;
        if (!session.ctx) return;
        session.ctx.drawImage(session.video, 0, 0, width, height);
        _emitCameraFrame(session, {
          imageData: session.ctx.getImageData(0, 0, width, height),
          requestId: session.requestId,
          timestamp: timestamp,
          width: width,
          height: height
        });
      }

      function _scheduleNativeCameraFrame(session) {
        if (!session || session.stopped) return;
        if (session.video && session.video.requestVideoFrameCallback) {
          session.videoFrameRequestId = session.video.requestVideoFrameCallback(function(now) {
            _captureNativeCameraFrame(session, now || performance.now());
            _scheduleNativeCameraFrame(session);
          });
          return;
        }
        session.animationFrameId = requestAnimationFrame(function(now) {
          _captureNativeCameraFrame(session, now);
          _scheduleNativeCameraFrame(session);
        });
      }

      function _watchNativeCameraStream(stream, requestId) {
        var canvas = _makeCameraCanvas(1, 1);
        var video = document.createElement('video');
        video.autoplay = true;
        video.muted = true;
        video.playsInline = true;
        video.srcObject = stream;

        var session = {
          animationFrameId: null,
          canvas: canvas,
          ctx: canvas.getContext('2d', { willReadFrequently: true }),
          requestId: requestId,
          stopped: false,
          stream: stream,
          video: video,
          videoFrameRequestId: null
        };
        _cameraSessions[requestId] = session;
        video.play().then(function() {
          _scheduleNativeCameraFrame(session);
        }).catch(function() {});
      }

      function requestCamera(constraints) {
        if (
          typeof navigator === 'undefined' ||
          !navigator.mediaDevices ||
          typeof navigator.mediaDevices.getUserMedia !== 'function'
        ) {
          return Promise.reject(new Error('Camera is not available in this browser.'));
        }
        var requestId = _makeCameraRequestId();
        delete _cameraStopNotified[requestId];
        return navigator.mediaDevices.getUserMedia(_cameraFallbackConstraints(constraints))
          .then(function(stream) {
            _wrapCameraStream(stream, requestId);
            _watchNativeCameraStream(stream, requestId);
            return stream;
          });
      }

      function stopCamera(stream) {
        var requestId = typeof stream === 'string'
          ? stream
          : stream && stream.__clayCameraRequestId
          ? stream.__clayCameraRequestId
          : null;
        var session = requestId ? _cameraSessions[requestId] : null;
        if (requestId) delete _cameraSessions[requestId];
        if (session) {
          session.stopped = true;
          if (typeof session.videoFrameRequestId === 'number' && session.video) {
            session.video.cancelVideoFrameCallback && session.video.cancelVideoFrameCallback(session.videoFrameRequestId);
          }
          if (typeof session.animationFrameId === 'number') {
            cancelAnimationFrame(session.animationFrameId);
          }
          if (session.video) {
            session.video.pause();
            session.video.srcObject = null;
          }
          if (session.canvas && session.canvas.remove) session.canvas.remove();
          stream = session.stream;
        }
        if (stream && stream.getTracks) {
          var tracks = stream.getTracks();
          for (var i = 0; i < tracks.length; i++) {
            if (tracks[i] && typeof tracks[i].stop === 'function') {
              tracks[i].stop();
            }
          }
        }
      }

      function onCameraFrame(callback) {
        if (typeof callback !== 'function') {
          return function() {};
        }
        _cameraFrameListeners.push(callback);
        return function() {
          var next = [];
          for (var i = 0; i < _cameraFrameListeners.length; i++) {
            if (_cameraFrameListeners[i] !== callback) next.push(_cameraFrameListeners[i]);
          }
          _cameraFrameListeners = next;
        };
      }



      function _applyBgCSS() {
        _detectCanvas();
        if (!_canvas) return;
        if (_bgState.mode === 'none') {
          _canvas.style.background = '';
        } else if (_bgState.mode === 'solid') {
          _canvas.style.background = _bgState.color;
        } else if (_bgState.mode === 'image') {
          if (_bgState.imageDataURL) {
            var fitCss = _bgState.fit === 'fill' ? '100% 100%' : _bgState.fit;
            _canvas.style.backgroundColor = _bgState.color;
            _canvas.style.backgroundImage = 'url("' + _bgState.imageDataURL + '")';
            _canvas.style.backgroundSize = fitCss;
            _canvas.style.backgroundPosition = 'center';
            _canvas.style.backgroundRepeat = 'no-repeat';
          } else {
            _canvas.style.backgroundImage = '';
            _canvas.style.backgroundColor = _bgState.color;
          }
        }
      }

      function setBackground(state) {
        state = state || {};
        _bgState.mode = state.mode || 'none';
        _bgState.color = state.color || '#ffffff';
        _bgState.fit = state.fit || 'cover';
        if (state.image && state.image !== _bgState.imageDataURL) {
          _bgState.imageDataURL = state.image;
          _bgState.imageEl = null;
          _applyBgCSS();
          var img = new Image();
          img.onload = function() {
            if (_bgState.imageDataURL !== state.image) return;
            _bgState.imageEl = img;
          };
          img.src = state.image;
        } else if (!state.image) {
          _bgState.imageEl = null;
          _bgState.imageDataURL = null;
        }
        _applyBgCSS();
      }

      function getBackground() {
        return { mode: _bgState.mode, color: _bgState.color, fit: _bgState.fit };
      }

      function setCanvas(el) {
        _canvas = el;
        _area = el ? el.parentElement : document.querySelector('.tool-canvas-area');
        if (_bgState.mode !== 'none') _applyBgCSS();
      }

      function setExportDimensions(w, h) {
        _detectCanvas();
        _exportMode = 'fixed';
        _exportWidth = Math.max(1, Math.round(w || 1));
        _exportHeight = Math.max(1, Math.round(h || 1));
        if (_canvas) {
          _canvas.width = _exportWidth;
          _canvas.height = _exportHeight;
        }
        if (window.p5 && typeof window.resizeCanvas === 'function') window.resizeCanvas(_exportWidth, _exportHeight);
        if (window.renderer && window.renderer.setSize) window.renderer.setSize(_exportWidth, _exportHeight, false);
        if (window.hydra && window.hydra.setResolution) window.hydra.setResolution(_exportWidth, _exportHeight);
        window.dispatchEvent(new Event('resize'));
      }

      function fitToArea() {}

      function getExportDimensions() {
        if (_exportMode === 'fixed') return { width: _exportWidth, height: _exportHeight, mode: 'fixed' };
        _detectCanvas();
        return { width: _canvas ? _canvas.width : 0, height: _canvas ? _canvas.height : 0, mode: 'auto' };
      }

      function isFixedExportMode() { return _exportMode === 'fixed'; }

      function _onAreaResize() {
        var r = window.renderer || window.threeRenderer;
        if (!r || !r.setSize) return;
        if (_resizeRAF) cancelAnimationFrame(_resizeRAF);
        _resizeRAF = requestAnimationFrame(function() {
          _detectCanvas();
          if (!_area) return;
          var w = _area.clientWidth;
          var h = _area.clientHeight;
          if (w <= 0 || h <= 0) return;
          r.setSize(w, h);
          window.dispatchEvent(new Event('resize'));
        });
      }
      if (typeof ResizeObserver !== 'undefined' && _area) {
        new ResizeObserver(_onAreaResize).observe(_area);
      }
      window.addEventListener('resize', _onAreaResize);

      setTimeout(function() {
        _detectCanvas();
        if (_bgState.mode !== 'none') _applyBgCSS();
      }, 500);

      function getMousePos(event) {
        _detectCanvas();
        if (!_canvas) return { x: 0, y: 0 };
        var rect = _canvas.getBoundingClientRect();
        var scaleX = _canvas.width / rect.width;
        var scaleY = _canvas.height / rect.height;
        var touch = event.touches && event.touches[0]
          ? event.touches[0]
          : event.changedTouches && event.changedTouches[0]
          ? event.changedTouches[0]
          : null;
        var clientX = touch ? touch.clientX : event.clientX;
        var clientY = touch ? touch.clientY : event.clientY;
        return {
          x: (clientX - rect.left) * scaleX,
          y: (clientY - rect.top) * scaleY
        };
      }

      function drawImage(ctx, img, x, y, w, h, fit) {
        if (!img || !img.width || !img.height) return;
        fit = fit || 'cover';
        var ar = img.width / img.height;
        var car = w / h;
        var sx = 0, sy = 0, sw = img.width, sh = img.height;
        var dx = x, dy = y, dw = w, dh = h;

        if (fit === 'cover') {
          if (ar > car) { sw = img.height * car; sx = (img.width - sw) / 2; }
          else { sh = img.width / car; sy = (img.height - sh) / 2; }
        } else if (fit === 'contain') {
          if (ar > car) { dh = w / ar; dy = y + (h - dh) / 2; }
          else { dw = h * ar; dx = x + (w - dw) / 2; }
        }

        ctx.drawImage(img, sx, sy, sw, sh, dx, dy, dw, dh);
      }

      return {
        setCanvas: setCanvas,
        setBackground: setBackground,
        getBackground: getBackground,
        setExportDimensions: setExportDimensions,
        fitToArea: fitToArea,
        getExportDimensions: getExportDimensions,
        isFixedExportMode: isFixedExportMode,
        requestCamera: requestCamera,
        stopCamera: stopCamera,
        onCameraFrame: onCameraFrame,

        getMousePos: getMousePos,
        drawImage: drawImage
      };
    })();

    window.ChatoolyCanvas = window.CanvasRuntimeAPI;
    window.ChatoolyControls = window.ControlsAPI;

    (function() {
      var srcDesc = Object.getOwnPropertyDescriptor(HTMLImageElement.prototype, 'src');
      if (srcDesc && srcDesc.set) {
        Object.defineProperty(HTMLImageElement.prototype, 'src', {
          get: srcDesc.get,
          set: function(val) {
            if (val && typeof val === 'string' && !val.startsWith('data:') && !this.crossOrigin) {
              this.crossOrigin = 'anonymous';
            }
            srcDesc.set.call(this, val);
          },
          configurable: true,
          enumerable: true
        });
      }
    })();

    window.loadImage = function(src, callback) {
      var img = new Image();
      if (src && typeof src === 'string' && !src.startsWith('data:')) {
        img.crossOrigin = 'anonymous';
      }
      img.onload = function() { if (callback) callback(img); };
      img.onerror = function() { console.error('Failed to load image:', src); };
      img.src = src;
      return img;
    };
  
  </script>
  <script>
    var canvas = document.getElementById('canvas');
    var ctx = canvas.getContext('2d');
    var __ctArea = canvas.parentElement;

    function resizeCanvas() {
      const dpr = window.devicePixelRatio || 1;

      canvas.style.width = "100vw";
      canvas.style.height = "100dvh";

      canvas.width = Math.floor(window.innerWidth * dpr);
      canvas.height = Math.floor(window.innerHeight * dpr);

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    window.addEventListener('resize', resizeCanvas);
    window.addEventListener('orientationchange', resizeCanvas);
    resizeCanvas();

    var controls = (function() {
      var _v = {"auto_mode":false,"pulses_active":false,"drone_vol":0,"pulses_vol":-11,"rain_vol":28,"bell_vol":6,"echo_level":90,"reverb_level":90,"bg_blur":2,"sensitivity":1,"grid_color":"#ffffff","imageInput":"https://base44.app/api/apps/69cbcd44d3da2a5cef013f5e/files/mp/public/69cbcd44d3da2a5cef013f5e/a1e019fcc_imageInput_mpnfptak.jpg"};
      var _defaults = JSON.parse(JSON.stringify(_v));
      function _hexToRgb(hex) {
        var h = String(hex || '').replace('#', '');
        if (h.length === 3) h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
        if (h.length !== 6 || !/^[0-9a-fA-F]{6}$/.test(h)) return null;
        return {
          r: parseInt(h.slice(0, 2), 16),
          g: parseInt(h.slice(2, 4), 16),
          b: parseInt(h.slice(4, 6), 16)
        };
      }
      function _clamp(n, min, max) { return Math.min(max, Math.max(min, n)); }
      function _hexToRgbaCss(hex, opacity0to100) {
        var rgb = _hexToRgb(hex);
        if (!rgb) return 'rgba(0,0,0,1)';
        var op = opacity0to100 != null && !isNaN(Number(opacity0to100)) ? Number(opacity0to100) : 100;
        var a = _clamp(op, 0, 100) / 100;
        return 'rgba(' + rgb.r + ',' + rgb.g + ',' + rgb.b + ',' + a + ')';
      }
      var api = {
        get: function(k) { return _v[k]; },
        getAll: function() { return Object.assign({}, _v); },
        getDefaults: function() { return JSON.parse(JSON.stringify(_defaults)); },
        getColorWithAlpha: function(baseKey) { return _hexToRgbaCss(_v[baseKey], _v[baseKey + '_opacity']); },
        set: function(k, v) { _v[k] = v; },
        onChange: function() {},
        onAny: function() {},
        onAction: function() {}
      };
      window.ControlsAPI = api;
      window.ChatoolyControls = api;
      return api;
    })();

    

    // Creative Code
    {
      // @clay-no-bg-control
/**
 * AETHER RAIN — Gesture-Controlled Atmospheric Instrument
 * Optimized for robust tracking and immersive sound.
 */

let isStarted = false;
let handLandmarker = null;
let latestResults = null;
let bgImage = new Image();
bgImage.crossOrigin = "anonymous";
let bgImageLoaded = false;

bgImage.onload = function () {
  bgImageLoaded = true;
};

bgImage.onerror = function () {
  bgImageLoaded = false;
  console.warn("background image failed to load");
};

bgImage.src = controls.get('imageInput');

// Audio Engine State
let audioCtxStarted = false;
const audio = {
  master: null,
  reverb: null,
  delay: null,
  filter: null,
  drone: null,
  droneGain: null,
  pulseSynth: null,
  pulseGain: null,
  pulseLoop: null,
  rain: null,
  rainGain: null,
  rainFilter: null,
  bells: null,
  bellGain: null,
  highBells: null,
  highBellGain: null
};

let lastHighBellTime = 0;

// Grid State
const GRID_SIZE = 45;
let grid = [];
let prevHandStates = [];
let smoothedRainEnergy = 0;

async function initMediaPipe() {
  try {
    const vision = await import("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/vision_bundle.mjs");
    const filesetResolver = await vision.FilesetResolver.forVisionTasks(
      "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/wasm"
    );
    handLandmarker = await vision.HandLandmarker.createFromOptions(filesetResolver, {
      baseOptions: {
        modelAssetPath: "https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/1/hand_landmarker.task",
        delegate: "CPU"
      },
      runningMode: "VIDEO",
      numHands: 2,
      minHandDetectionConfidence: 0.4,
      minHandPresenceConfidence: 0.4
    });
    console.log("mediapipe ready");
    const btn = document.querySelector('#start-btn-text');
    if (btn) btn.innerText = "start experience";
  } catch (e) {
    console.error("mediapipe init error:", e);
    const btn = document.querySelector('#start-btn-text');
    if (btn) btn.innerText = "start (audio only)";
  }
}

function setupAudio() {
  if (!window.Tone) return;
  
  // Master Chain
  audio.master = new Tone.Gain(0.8).toDestination();
  audio.reverb = new Tone.Reverb({ decay: 12, wet: controls.get('reverb_level') / 100 }).connect(audio.master);
  audio.delay = new Tone.FeedbackDelay("8n", 0.5).connect(audio.reverb);
  audio.delay.wet.value = controls.get('echo_level') / 100;
  audio.filter = new Tone.Filter(2000, "lowpass").connect(audio.delay);

  // Drone 1: Deep base
  audio.droneGain = new Tone.Gain(0).connect(audio.filter);
  audio.drone = new Tone.FatOscillator("C2", "sawtooth", 40).connect(audio.droneGain);

  // Atmospheric Pulsos (Kick-Bell)
  Tone.Transport.bpm.value = 60; 
  audio.pulseGain = new Tone.Gain(0).connect(audio.filter);
  audio.pulseSynth = new Tone.FMSynth({
    harmonicity: 2.5,
    modulationIndex: 5,
    oscillator: { type: "sine" },
    envelope: { attack: 0.01, decay: 0.5, sustain: 0, release: 1 },
    modulation: { type: "square" },
    modulationEnvelope: { attack: 0.01, decay: 0.2, sustain: 0, release: 0.2 }
  }).connect(audio.pulseGain);
  
  audio.pulseLoop = new Tone.Loop((time) => {
    audio.pulseSynth.triggerAttackRelease("C2", "8n", time);
  }, "4m"); 

  // Rain: Textural noise
  audio.rainGain = new Tone.Gain(0).connect(audio.filter);
  audio.rainFilter = new Tone.AutoFilter({ 
    frequency: "2n", 
    baseFrequency: 800, 
    octaves: 3,
    type: "sine"
  }).connect(audio.rainGain);
  audio.rain = new Tone.Noise("pink").connect(audio.rainFilter);

  // Bells: FM Synthesis
  audio.bellGain = new Tone.Gain(0).connect(audio.filter);
  audio.bells = new Tone.PolySynth(Tone.FMSynth, {
    harmonicity: 3.5,
    modulationIndex: 20,
    oscillator: { type: "sine" },
    envelope: { attack: 0.01, decay: 2, sustain: 0, release: 3 },
    modulation: { type: "triangle" }
  }).connect(audio.bellGain);

  // High Bells: Ethereal occasional chimes
  audio.highBellGain = new Tone.Gain(0).connect(audio.delay);
  audio.highBells = new Tone.FMSynth({
    harmonicity: 4.5,
    modulationIndex: 15,
    oscillator: { type: "sine" },
    envelope: { attack: 0.01, decay: 0.5, sustain: 0, release: 1.5 },
    modulation: { type: "square" },
    modulationEnvelope: { attack: 0.01, decay: 0.2, sustain: 0, release: 0.2 }
  }).connect(audio.highBellGain);
}

async function startExperience() {
  if (isStarted) return;
  
  try {
    // 1. Immediate Audio Start
    if (window.Tone) {
      await Tone.start();
      setupAudio();
      audioCtxStarted = true;
      Tone.Transport.start();
      if (audio.drone) audio.drone.start();
      if (audio.pulseLoop && controls.get('pulses_active')) audio.pulseLoop.start(0);
      if (audio.rain) audio.rain.start();
      if (audio.rainFilter) audio.rainFilter.start();
    }

    // 2. Camera Start
    try {
      await CanvasRuntimeAPI.requestCamera({ video: true });
      CanvasRuntimeAPI.onCameraFrame((frame) => {
        if (handLandmarker && frame.canvas) {
          try {
            const results = handLandmarker.detectForVideo(frame.canvas, performance.now());
            if (results) latestResults = results;
          } catch (e) { }
        }
      });
    } catch (camErr) {
      console.warn("Camera access denied:", camErr);
    }

    // 3. UI Transition
    isStarted = true;
    const ov = document.getElementById('start-overlay');
    if (ov) {
      ov.style.opacity = '0';
      setTimeout(() => ov.style.display = 'none', 500);
    }
    
  } catch (e) {
    console.error("Start Error:", e);
    isStarted = true;
    const ov = document.getElementById('start-overlay');
    if (ov) ov.style.display = 'none';
  }
}

function initGrid() {
  grid = [];
  for (let x = 0; x < GRID_SIZE; x++) {
    for (let y = 0; y < GRID_SIZE; y++) {
      grid.push({
        x: x / (GRID_SIZE - 1),
        y: y / (GRID_SIZE - 1),
        brightness: 0
      });
    }
  }
}
initGrid();

function draw(timestamp) {
  const w = window.innerWidth;
  const h = window.innerHeight;
  const t = timestamp * 0.001;

  ctx.clearRect(0, 0, w, h);

  // 1. Background Image
  const blur = controls.get('bg_blur');
  ctx.save();
  ctx.fillStyle = "#000";
  ctx.fillRect(0, 0, w, h);

  if (bgImageLoaded) {
    if (blur > 0) ctx.filter = `blur(${blur}px)`;
    CanvasRuntimeAPI.drawImage(ctx, bgImage, 0, 0, w, h, 'cover');
  }

  ctx.restore();

  if (!isStarted) {
    requestAnimationFrame(draw);
    return;
  }

  // 2. Update Audio Volumes
  if (audioCtxStarted) {
    const droneVol = controls.get('drone_vol') / 100;
    const pulsesVol = Tone.dbToGain(controls.get('pulses_vol'));
    const bellVol = controls.get('bell_vol') / 100;
    
    if (audio.droneGain) audio.droneGain.gain.rampTo(droneVol * 0.5, 0.1);
    if (audio.pulseGain) audio.pulseGain.gain.rampTo(pulsesVol, 0.1);
    if (audio.bellGain) audio.bellGain.gain.rampTo(bellVol * 0.8, 0.1);
    if (audio.highBellGain) audio.highBellGain.gain.rampTo(bellVol * 0.6, 0.1);
  }

  let activeHands = [];
  const sensitivity = controls.get('sensitivity') || 1;

  // 3. Real Hands
  if (latestResults && latestResults.landmarks) {
    latestResults.landmarks.forEach((hand) => {
      const palm = hand[0];
      const thumbTip = hand[4];
      const indexTip = hand[8];
      
      let openness = 0;
      [8, 12, 16, 20].forEach(idx => {
        openness += Math.hypot(hand[idx].x - palm.x, hand[idx].y - palm.y);
      });
      openness = Math.min(1, openness * 1.5);

      const pinchDist = Math.hypot(indexTip.x - thumbTip.x, indexTip.y - thumbTip.y);
      const isPinching = pinchDist < 0.06;

      activeHands.push({
        x: 1 - palm.x,
        y: palm.y,
        openness,
        isPinching,
        isReal: true,
        landmarks: hand
      });
    });
  }

  // 4. Auto Mode
  if (controls.get('auto_mode') && activeHands.length < 2) {
    const count = 2 - activeHands.length;
    for (let i = 0; i < count; i++) {
      const offset = i * Math.PI + t * 0.2;
      activeHands.push({
        x: 0.5 + Math.sin(t * 0.4 + offset) * 0.3,
        y: 0.5 + Math.cos(t * 0.6 + offset) * 0.2,
        openness: 0.5 + Math.sin(t * 1.5) * 0.3,
        isPinching: Math.sin(t * 2.5 + offset) > 0.85,
        isReal: false
      });
    }
  }

  // 5. Interaction
  let currentHandStates = [];
  let frameRainEnergy = 0;
  let maxFreq = 400;

  activeHands.forEach((hand, i) => {
    const prev = prevHandStates[i];

    let movementSpeed = 0;
    let opennessVelocity = 0;
    let motionEnergy = 0;

    if (prev) {
      const dx = hand.x - prev.x;
      const dy = hand.y - prev.y;

      movementSpeed = Math.sqrt(dx * dx + dy * dy);
      opennessVelocity = Math.abs(hand.openness - prev.openness);

      // More physical hand-to-bell sensitivity.
      // Small motion produces subtle bells; faster finger/hand motion produces brighter response.
      motionEnergy =
        (movementSpeed * 12 * sensitivity) +
        (opennessVelocity * 8 * sensitivity);

      frameRainEnergy += motionEnergy;
    } else {
      frameRainEnergy += (1 - hand.openness) * 0.8;
    }

    currentHandStates[i] = {
      x: hand.x,
      y: hand.y,
      openness: hand.openness,
      lastBellTime: prev?.lastBellTime || 0,
      smoothEnergy: ((prev?.smoothEnergy || 0) * 0.82) + (motionEnergy * 0.18)
    };

    const handState = currentHandStates[i];

    if (audioCtxStarted) {
      maxFreq = Math.max(maxFreq, 400 + hand.y * 7000);

      const smoothEnergy = handState.smoothEnergy;
      let pinchStrength = 0;

      if (hand.landmarks && hand.landmarks[8] && hand.landmarks[4]) {
        pinchStrength = 1 - Math.min(
          1,
          Math.hypot(
            hand.landmarks[8].x - hand.landmarks[4].x,
            hand.landmarks[8].y - hand.landmarks[4].y
          ) * 18
        );
      } else if (hand.isPinching) {
        pinchStrength = 1;
      }

      const now = performance.now();
      const dynamicCooldown = 220 - Math.min(140, smoothEnergy * 40);
      const canTrigger = now - handState.lastBellTime > dynamicCooldown;

      const shouldTrigger =
        (smoothEnergy > 0.035 || pinchStrength > 0.65) && canTrigger;

      if (shouldTrigger) {
        handState.lastBellTime = now;

        const scale = ["G6", "Bb6", "C7", "D7", "F7", "G7", "A7", "C8"];
        const noteIndex = Math.floor(Math.max(0, Math.min(0.999, hand.y)) * scale.length);
        const note = scale[noteIndex];

        const velocity = Math.min(
          1,
          0.18 + (smoothEnergy * 2.4) + (pinchStrength * 0.6)
        );

        if (audio.bells && note) {
          audio.bells.triggerAttackRelease(
            note,
            pinchStrength > 0.7 ? "2n" : "8n",
            Tone.now(),
            velocity
          );
        }

        if (audio.highBells && smoothEnergy > 0.08) {
          const highScale = ["C7", "E7", "G7", "B7", "D8"];
          const highNote = highScale[Math.floor(Math.random() * highScale.length)];

          audio.highBells.triggerAttackRelease(
            highNote,
            "16n",
            Tone.now(),
            velocity * 0.6
          );
        }

        grid.forEach(p => {
          if (Math.hypot(p.x - hand.x, p.y - hand.y) < 0.1) {
            p.brightness = 255;
          }
        });
      }
    }

    grid.forEach(p => {
      const d = Math.hypot(p.x - hand.x, p.y - hand.y);
      if (d < 0.18) {
        p.brightness = Math.max(p.brightness, (1 - d / 0.18) * 255);
      }
    });
  });

  prevHandStates = currentHandStates;

  if (audioCtxStarted) {
    if (audio.filter) audio.filter.frequency.rampTo(maxFreq, 0.2);
    smoothedRainEnergy = smoothedRainEnergy * 0.8 + frameRainEnergy * 0.2;
    const rainVolControl = controls.get('rain_vol') / 100;
    const targetRainVol = Math.min(1, smoothedRainEnergy * 0.8) * rainVolControl;
    if (audio.rainGain) audio.rainGain.gain.rampTo(targetRainVol, 0.1);
    const targetRainFreq = 300 + smoothedRainEnergy * 4000;
    if (audio.rainFilter) audio.rainFilter.frequency.rampTo(Math.min(10000, targetRainFreq), 0.1);
  }

  // 6. Render Grid
  const gridColor = controls.get('grid_color');
  grid.forEach(p => {
    if (p.brightness > 1) {
      const alpha = Math.floor(p.brightness).toString(16).padStart(2, '0');
      ctx.fillStyle = gridColor + alpha;
      ctx.beginPath();
      ctx.arc(p.x * w, p.y * h, 2, 0, Math.PI * 2);
      ctx.fill();
      p.brightness *= 0.94;
    }
  });

  // 7. Render Hand Landmarks
  activeHands.forEach(hand => {
    if (hand.isReal && hand.landmarks) {
      ctx.strokeStyle = "rgba(255, 255, 255, 0.5)";
      ctx.lineWidth = 1.5;
      const connections = [[0,1,2,3,4], [0,5,6,7,8], [5,9,13,17], [0,17,18,19,20], [9,10,11,12], [13,14,15,16]];
      connections.forEach(path => {
        ctx.beginPath();
        path.forEach((idx, i) => {
          const lm = hand.landmarks[idx];
          const lx = (1 - lm.x) * w;
          const ly = lm.y * h;
          if (i === 0) ctx.moveTo(lx, ly); else ctx.lineTo(lx, ly);
        });
        ctx.stroke();
      });
      hand.landmarks.forEach((lm) => {
        const lx = (1 - lm.x) * w;
        const ly = lm.y * h;
        ctx.fillStyle = hand.isPinching ? "#fff" : gridColor;
        ctx.beginPath();
        ctx.arc(lx, ly, hand.isPinching ? 6 : 4, 0, Math.PI * 2);
        ctx.fill();
      });
    }
  });

  // 8. Status Indicator
  if (isStarted) {
    ctx.fillStyle = "rgba(255,255,255,0.6)";
    ctx.font = "bold 11px Helvetica, Arial, sans-serif";
    ctx.textAlign = "left";
    const status = handLandmarker ? (latestResults && latestResults.landmarks.length > 0 ? "tracking active" : "searching for hands...") : "initializing model...";
    ctx.fillText(status, 30, h - 30);
  }

  requestAnimationFrame(draw);
}

// UI Overlay
const overlay = document.createElement('div');
overlay.id = 'start-overlay';
overlay.style.position = 'fixed';
overlay.style.top = '0';
overlay.style.left = '0';
overlay.style.width = '100%';
overlay.style.height = '100%';
overlay.style.background = 'rgba(0,0,0,0.5)';
overlay.style.backdropFilter = 'blur(15px)';
overlay.style.display = 'flex';
overlay.style.flexDirection = 'column';
overlay.style.alignItems = 'center';
overlay.style.justifyContent = 'center';
overlay.style.zIndex = '1000';
overlay.style.cursor = 'pointer';
overlay.style.color = 'white';
overlay.style.fontFamily = '"Helvetica Neue", Helvetica, Arial, sans-serif';
overlay.style.fontWeight = 'bold';
overlay.style.transition = 'opacity 0.5s ease';

overlay.innerHTML = `
  <div id="start-btn-text" style="transition: all 0.4s ease;">
    start experience
  </div>
  <p style="margin-top: 16px; opacity: 0.6; font-size: 0.8rem; letter-spacing: -0.01em;">
    activate camera & audio
  </p>
`;

overlay.onclick = startExperience;
document.querySelector('.tool-canvas-area').appendChild(overlay);

controls.onChange('imageInput', (url) => { bgImageLoaded = false; bgImage.src = url; });
controls.onChange('pulses_active', (active) => {
  if (audioCtxStarted && audio.pulseLoop) {
    if (active) audio.pulseLoop.start(0);
    else audio.pulseLoop.stop();
  }
});
controls.onChange('echo_level', (val) => { if (audioCtxStarted && audio.delay) audio.delay.wet.value = val / 100; });
controls.onChange('reverb_level', (val) => { if (audioCtxStarted && audio.reverb) audio.reverb.wet.value = val / 100; });

initMediaPipe();
requestAnimationFrame(draw);
    }

    
  </script>
</body>
</html>
